# ========================================
# APEX CHAT ENVIRONMENT CONFIGURATION
# ========================================

# -----------------------------------------
# SUPABASE CONFIGURATION (Auth & Database)
# -----------------------------------------

# Supabase Project URL and Anon Key
# Get these from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# -----------------------------------------
# BACKEND CONFIGURATION (Server-Side)
# -----------------------------------------

# Cerebras AI API Key (for backend AI routing)
# Get it from: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Server Port (default: 5000)
PORT=5000

# Node Environment (development | production)
NODE_ENV=development

# -----------------------------------------
# FRONTEND CONFIGURATION (Client-Side)
# -----------------------------------------

# API Base URL (usually http://localhost:5000 for dev)
VITE_API_BASE_URL=http://localhost:5000

# Groq AI API Key (for client-side hybrid AI)
# CRITICAL: Required for Firebase deployments!
# Get it from: https://console.groq.com/
VITE_GROQ_API_KEY=your_groq_api_key_here

# DeepSeek API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here

# API-Football / API-Sports key (server-side only, used by Apex Search for football fixtures)
API_FOOTBALL_KEY=your_api_football_key_here

# OpenRouter API Key (for model routing)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Serper API Key (for web search)
VITE_SERPER_API_KEY=your_serper_api_key_here


# -----------------------------------------
# INSTRUCTIONS
# -----------------------------------------

# 1. Copy this file to `.env.local`
# 2. Replace placeholder values with real API keys
# 3. NEVER commit `.env.local` to Git
# 4. For Firebase deployment, add VITE_* keys to Firebase environment config

# -----------------------------------------
# HOW TO GET API KEYS
# -----------------------------------------

# CEREBRAS (Backend):
# 1. Go to https://cloud.cerebras.ai/
# 2. Sign up / Log in
# 3. Navigate to API Keys
# 4. Create new key
# 5. Copy and paste here

# GROQ (Frontend):
# 1. Go to https://console.groq.com/
# 2. Sign up / Log in
# 3. Go to API Keys section
# 4. Create new key
# 5. Copy and paste here

# SUPABASE:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings → API
# 4. Copy the Project URL and anon/public key
