# ========================================
# APEX CHAT ENVIRONMENT CONFIGURATION
# ========================================

# -----------------------------------------
# BACKEND CONFIGURATION (Server-Side)
# -----------------------------------------

# Cerebras AI API Key (for backend AI routing)
# Get it from: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Server Port (default: 5000)
PORT=5000

# Node Environment (development | production)
NODE_ENV=development

# -----------------------------------------
# FRONTEND CONFIGURATION (Client-Side)
# -----------------------------------------

# API Base URL (usually http://localhost:5000 for dev)
VITE_API_BASE_URL=http://localhost:5000

# Groq AI API Key (for client-side hybrid AI)
# CRITICAL: Required for Firebase deployments!
# Get it from: https://console.groq.com/
VITE_GROQ_API_KEY=your_groq_api_key_here

# DeepSeek API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here


# -----------------------------------------
# INSTRUCTIONS
# -----------------------------------------

# 1. Copy this file to `.env` or `.env.local`
# 2. Replace placeholder values with real API keys
# 3. NEVER commit `.env` or `.env.local` to Git
# 4. For Firebase deployment, add VITE_GROQ_API_KEY to Firebase environment config

# -----------------------------------------
# HOW TO GET API KEYS
# -----------------------------------------

# CEREBRAS (Backend):
# 1. Go to https://cloud.cerebras.ai/
# 2. Sign up / Log in
# 3. Navigate to API Keys
# 4. Create new key
# 5. Copy and paste here

# GROQ (Frontend - Firebase):
# 1. Go to https://console.groq.com/
# 2. Sign up / Log in
# 3. Go to API Keys section
# 4. Create new key
# 5. Copy and paste here
# 6. IMPORTANT: Groq is FREE and very fast!

# -----------------------------------------
# FIREBASE DEPLOYMENT SETUP
# -----------------------------------------

# For Firebase deployment, you MUST set VITE_GROQ_API_KEY
# Option 1: Add to Firebase environment variables
# Option 2: Hardcode in vite.config.ts (NOT RECOMMENDED for security)
